networks:
  nacos-net:
    driver: bridge

services:
{% if nacos_db_mode == 'compose' %}
  mysql:
    image: "{{ nacos_mysql_image }}"
    container_name: "{{ nacos_mysql_container_name }}"
    restart: "{{ nacos_docker_restart_policy }}"
    environment:
      MYSQL_ROOT_PASSWORD: "{{ nacos_mysql_root_password }}"
      MYSQL_DATABASE: "{{ nacos_db.name }}"
      MYSQL_USER: "{{ nacos_db.user }}"
      MYSQL_PASSWORD: "{{ nacos_db.password }}"
    command:
      - "--character-set-server=utf8mb4"
      - "--collation-server=utf8mb4_unicode_ci"
      - "--default-time-zone=+8:00"
    volumes:
      - "./mysql:/var/lib/mysql"
      - "./mysql-init:/docker-entrypoint-initdb.d:ro"
    networks:
      - nacos-net
    healthcheck:
      test: ["CMD", "mysqladmin", "ping", "-h", "localhost"]
      interval: 10s
      timeout: 5s
      retries: 10
      start_period: 30s
{% endif %}
{% if nacos_mode == 'cluster' and nacos_cluster_type == 'pseudo' %}
{# ========== 伪集群：单机多容器 Server ========== #}
{% for i in range(nacos_pseudo_nodes | int) %}
{% set http_port = nacos_pseudo_port_start | int + i * (nacos_pseudo_port_step | int) %}
{% set grpc_port = http_port + 1000 %}
{% set grpc_tls_port = http_port + 1001 %}
  {{ nacos_container_name }}-{{ i + 1 }}:
    image: "{{ nacos_image }}:{{ nacos_version }}"
    container_name: "{{ nacos_container_name }}-{{ i + 1 }}"
    restart: "{{ nacos_docker_restart_policy }}"
    hostname: "{{ nacos_container_name }}-{{ i + 1 }}"
{% if nacos_db_mode == 'compose' %}
    depends_on:
      mysql:
        condition: service_healthy
{% endif %}
    environment:
      MODE: "cluster"
      NACOS_DEPLOYMENT_TYPE: "server"
      NACOS_APPLICATION_PORT: "8848"
      PREFER_HOST_MODE: "hostname"
      NACOS_SERVERS: "{{ _nacos_pseudo_servers }}"
      NACOS_AUTH_ENABLE: "{{ nacos_auth_enabled | lower }}"
      NACOS_AUTH_TOKEN: "{{ nacos_auth_token }}"
      NACOS_AUTH_IDENTITY_KEY: "{{ nacos_auth_identity_key }}"
      NACOS_AUTH_IDENTITY_VALUE: "{{ nacos_auth_identity_value }}"
      SPRING_DATASOURCE_PLATFORM: "mysql"
      MYSQL_SERVICE_HOST: "{{ nacos_db.host }}"
      MYSQL_SERVICE_PORT: "{{ nacos_db.port }}"
      MYSQL_SERVICE_DB_NAME: "{{ nacos_db.name }}"
      MYSQL_SERVICE_USER: "{{ nacos_db.user }}"
      MYSQL_SERVICE_PASSWORD: "{{ nacos_db.password }}"
      MYSQL_SERVICE_DB_PARAM: "{{ nacos_db.params }}"
      MYSQL_DATABASE_NUM: "1"
    ports:
      - "{{ http_port }}:8848"
      - "{{ grpc_port }}:9848"
      - "{{ grpc_tls_port }}:9849"
    volumes:
      - "./logs/node{{ i + 1 }}:/home/nacos/logs"
      - "./data/node{{ i + 1 }}:/home/nacos/data"
    networks:
      - nacos-net
{% endfor %}
{% else %}
{# ========== 单机 / 真实集群 Server ========== #}
  {{ nacos_container_name }}:
    image: "{{ nacos_image }}:{{ nacos_version }}"
    container_name: "{{ nacos_container_name }}"
    restart: "{{ nacos_docker_restart_policy }}"
{% if nacos_db_mode == 'compose' %}
    depends_on:
      mysql:
        condition: service_healthy
{% endif %}
    environment:
      MODE: "{{ nacos_mode }}"
      NACOS_DEPLOYMENT_TYPE: "server"
      NACOS_APPLICATION_PORT: "8848"
      PREFER_HOST_MODE: "hostname"
{% if nacos_mode == 'cluster' %}
      NACOS_SERVERS: "{{ nacos_cluster_nodes | join(' ') }}"
{% endif %}
      NACOS_AUTH_ENABLE: "{{ nacos_auth_enabled | lower }}"
      NACOS_AUTH_TOKEN: "{{ nacos_auth_token }}"
      NACOS_AUTH_IDENTITY_KEY: "{{ nacos_auth_identity_key }}"
      NACOS_AUTH_IDENTITY_VALUE: "{{ nacos_auth_identity_value }}"
      SPRING_DATASOURCE_PLATFORM: "mysql"
      MYSQL_SERVICE_HOST: "{{ nacos_db.host }}"
      MYSQL_SERVICE_PORT: "{{ nacos_db.port }}"
      MYSQL_SERVICE_DB_NAME: "{{ nacos_db.name }}"
      MYSQL_SERVICE_USER: "{{ nacos_db.user }}"
      MYSQL_SERVICE_PASSWORD: "{{ nacos_db.password }}"
      MYSQL_SERVICE_DB_PARAM: "{{ nacos_db.params }}"
      MYSQL_DATABASE_NUM: "1"
    ports:
      - "{{ nacos_http_port }}:8848"
      - "{{ nacos_grpc_port }}:9848"
      - "{{ nacos_grpc_tls_port }}:9849"
      - "{{ nacos_raft_port }}:7848"
    volumes:
      - "./logs:/home/nacos/logs"
      - "./data:/home/nacos/data"
    networks:
      - nacos-net
{% endif %}
{% if nacos_deploy_console | default(true) | bool %}
{# ========== Console 独立容器 ========== #}
  {{ nacos_container_name }}-console:
    image: "{{ nacos_image }}:{{ nacos_version }}"
    container_name: "{{ nacos_container_name }}-console"
    restart: "{{ nacos_docker_restart_policy }}"
    environment:
      NACOS_DEPLOYMENT_TYPE: "console"
      NACOS_AUTH_ENABLE: "{{ nacos_auth_enabled | lower }}"
      NACOS_AUTH_ADMIN_ENABLE: "{{ nacos_web_login_enabled | lower }}"
      NACOS_AUTH_CONSOLE_ENABLE: "{{ nacos_web_login_enabled | lower }}"
      NACOS_AUTH_TOKEN: "{{ nacos_auth_token }}"
      NACOS_AUTH_IDENTITY_KEY: "{{ nacos_auth_identity_key }}"
      NACOS_AUTH_IDENTITY_VALUE: "{{ nacos_auth_identity_value }}"
    ports:
      - "{{ nacos_console_port }}:8080"
    volumes:
      - "./cluster.conf:/home/nacos/conf/cluster.conf"
      - "./logs/console:/home/nacos/logs"
    networks:
      - nacos-net
{% endif %}
