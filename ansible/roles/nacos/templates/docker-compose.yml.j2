services:
  nacos:
    image: "{{ nacos_image }}:{{ nacos_version }}"
    container_name: "{{ nacos_container_name }}"
    restart: "{{ nacos_docker_restart_policy }}"
    environment:
      MODE: "{{ nacos_mode }}"
      PREFER_HOST_MODE: "hostname"
      NACOS_AUTH_ENABLE: "{{ nacos_auth_enabled | lower }}"
      NACOS_AUTH_TOKEN: "{{ nacos_auth_token }}"
      NACOS_AUTH_IDENTITY_KEY: "{{ nacos_auth_identity_key }}"
      NACOS_AUTH_IDENTITY_VALUE: "{{ nacos_auth_identity_value }}"
{% if nacos_db_mode == 'mysql' %}
      SPRING_DATASOURCE_PLATFORM: "mysql"
      MYSQL_SERVICE_HOST: "{{ nacos_db.host }}"
      MYSQL_SERVICE_PORT: "{{ nacos_db.port }}"
      MYSQL_SERVICE_DB_NAME: "{{ nacos_db.name }}"
      MYSQL_SERVICE_USER: "{{ nacos_db.user }}"
      MYSQL_SERVICE_PASSWORD: "{{ nacos_db.password }}"
      MYSQL_DATABASE_NUM: "1"
{% endif %}
    ports:
      - "{{ nacos_http_port }}:8848"
      - "{{ nacos_grpc_port }}:9848"
      - "{{ nacos_grpc_tls_port }}:9849"
      - "{{ nacos_raft_port }}:7848"
    volumes:
      - "{{ nacos_conf_dir }}/application.properties:/home/nacos/conf/application.properties"
{% if nacos_mode == 'cluster' %}
      - "{{ nacos_conf_dir }}/cluster.conf:/home/nacos/conf/cluster.conf"
{% endif %}
      - "{{ nacos_logs_dir }}:/home/nacos/logs"
      - "{{ nacos_data_dir }}:/home/nacos/data"
